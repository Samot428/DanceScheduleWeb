# Kopiere diese Datei nach .env und fülle die Werte aus
# Auf Railway: diese Werte als Environment Variables eintragen

# Django
SECRET_KEY=dein-geheimer-schluessel-hier-generieren
DEBUG=False
ALLOWED_HOSTS=.railway.app,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://deine-app.railway.app

# Datenbank (Railway stellt DATABASE_URL automatisch bereit)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (Railway stellt REDIS_URL automatisch bereit)
REDIS_URL=redis://localhost:6379

# Media files
MEDIA_ROOT=/app/media
